{{ 'section-pps-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_alt = section.settings.heading | strip_html | escape
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --pps-hero-height-desktop: {{ section.settings.hero_height_desktop }}px;
    --pps-hero-height-mobile: {{ section.settings.hero_height_mobile }}px;
    --pps-hero-card-max-width: {{ section.settings.card_max_width }}px;
    --pps-hero-card-bg: {{ section.settings.card_background }};
    --pps-hero-card-border: {{ section.settings.card_border_color }};
    --pps-hero-heading-color: {{ section.settings.heading_color }};
    --pps-hero-text-color: {{ section.settings.text_color }};
    --pps-hero-accent: {{ section.settings.accent_color }};
    --pps-hero-button-bg: {{ section.settings.button_background }};
    --pps-hero-button-text: {{ section.settings.button_text_color }};
    --pps-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --pps-hero-section-gap: {{ section.settings.margin_bottom }}px;
  }
{% endstyle %}

<section class="pps-hero">
  <div class="pps-hero__media">
    {%- if section.settings.background_image != blank -%}
      {{
        section.settings.background_image
        | image_url: width: 2400
        | image_tag:
          class: 'pps-hero__image',
          widths: '750, 1100, 1500, 1780, 2000, 2400',
          alt: hero_alt,
          loading: 'eager'
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'pps-hero__image pps-hero__image--placeholder' }}
    {%- endif -%}

    <div class="pps-hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="pps-hero__content-wrap page-width">
    <div class="pps-hero__card">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pps-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="pps-hero__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <div class="pps-hero__subtext rte">{{ section.settings.subtext }}</div>
      {%- endif -%}

      <div class="pps-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
            class="pps-hero__button"
          >
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.microcopy != blank -%}
          <p class="pps-hero__microcopy">{{ section.settings.microcopy }}</p>
        {%- endif -%}
      </div>

      {%- assign has_highlights = false -%}
      {%- if section.settings.highlight_1 != blank or section.settings.highlight_2 != blank or section.settings.highlight_3 != blank -%}
        {%- assign has_highlights = true -%}
      {%- endif -%}

      {%- if has_highlights -%}
        <div class="pps-hero__highlights" aria-label="Highlights">
          {%- if section.settings.highlight_1 != blank -%}
            <span class="pps-hero__highlight">{{ section.settings.highlight_1 }}</span>
          {%- endif -%}
          {%- if section.settings.highlight_2 != blank -%}
            <span class="pps-hero__highlight">{{ section.settings.highlight_2 }}</span>
          {%- endif -%}
          {%- if section.settings.highlight_3 != blank -%}
            <span class="pps-hero__highlight">{{ section.settings.highlight_3 }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPS Hero",
  "tag": "section",
  "class": "section-pps-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Cherry Milk"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Soft. Sweet. A little dangerous."
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Baby tees, glossy details, and cherry-red attitude for your main-character closet.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy",
      "default": "Premium fits. Fast favorites. Easy to style."
    },
    {
      "type": "text",
      "id": "highlight_1",
      "label": "Highlight 1",
      "default": "Baby-tee energy"
    },
    {
      "type": "text",
      "id": "highlight_2",
      "label": "Highlight 2",
      "default": "Cherry-red accents"
    },
    {
      "type": "text",
      "id": "highlight_3",
      "label": "Highlight 3",
      "default": "Soft cotton feel"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "min": 420,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Desktop height",
      "default": 580
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "min": 360,
      "max": 760,
      "step": 20,
      "unit": "px",
      "label": "Mobile height",
      "default": 520
    },
    {
      "type": "range",
      "id": "card_max_width",
      "min": 320,
      "max": 760,
      "step": 20,
      "unit": "px",
      "label": "Card width",
      "default": 560
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "Image overlay",
      "default": 10
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#fff9f3"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#f3c8d3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#c51f3a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#22181b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6b565d"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#c51f3a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "PPS Hero"
    }
  ]
}
{% endschema %}
