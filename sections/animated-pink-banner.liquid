{{ 'section-animated-pink-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .animated-banner-{{ section.id }} {
    --animation-type: {{ section.settings.animation_type }};
    --banner-background: {{ section.settings.banner_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="animated-banner-wrapper section-{{ section.id }}-padding">
  <div class="animated-banner animated-banner-{{ section.id }} animated-banner--{{ section.settings.animation_type }}">
    <div class="animated-banner__content">
      {%- if section.settings.banner_text != blank -%}
        <h2 class="animated-banner__text h3">
          {{ section.settings.banner_text | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.banner_subtext != blank -%}
        <p class="animated-banner__subtext">
          {{ section.settings.banner_subtext | escape }}
        </p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.animated_pink_banner.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "banner_text",
      "default": "✨ Willkommen! ✨",
      "label": "Banner Text"
    },
    {
      "type": "text",
      "id": "banner_subtext",
      "default": "Entdecke unsere neuen Produkte",
      "label": "Banner Untertext"
    },
    {
      "type": "select",
      "id": "animation_type",
      "options": [
        {
          "value": "float",
          "label": "Schwebend (Float)"
        },
        {
          "value": "bounce",
          "label": "Springend (Bounce)"
        },
        {
          "value": "slide",
          "label": "Gleitend (Slide)"
        },
        {
          "value": "pulse",
          "label": "Pulsierend (Pulse)"
        }
      ],
      "default": "float",
      "label": "Animationstyp"
    },
    {
      "type": "color",
      "id": "banner_color",
      "default": "#E8B4D0",
      "label": "Banner Hintergrundfarbe"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#FFFFFF",
      "label": "Text Farbe"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Innenabstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Innenabstand unten",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.animated_pink_banner.presets.name"
    }
  ]
}
{% endschema %}
