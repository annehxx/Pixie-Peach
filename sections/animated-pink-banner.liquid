{{ 'section-animated-pink-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .animated-banner-{{ section.id }} {
    --animation-type: {{ section.settings.animation_type }};
    --banner-background: {{ section.settings.banner_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="animated-banner-wrapper section-{{ section.id }}-padding">
  <div class="animated-banner animated-banner-{{ section.id }} animated-banner--ticker">
    <div class="animated-banner__ticker">
      {%- if section.settings.banner_text != blank -%}
        <div class="animated-banner__text-scroll">
          <span>{{ section.settings.banner_text | escape }}</span>
          <span>{{ section.settings.banner_text | escape }}</span>
          <span>{{ section.settings.banner_text | escape }}</span>
          <span>{{ section.settings.banner_text | escape }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.animated_pink_banner.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "banner_text",
      "default": "For the pop culture obsessed",
      "label": "Banner Text"
    },

    {
      "type": "color",
      "id": "banner_color",
      "default": "#E8B4D0",
      "label": "Banner Hintergrundfarbe"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#FFFFFF",
      "label": "Text Farbe"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Innenabstand oben",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Innenabstand unten",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.animated_pink_banner.presets.name"
    }
  ]
}
{% endschema %}
