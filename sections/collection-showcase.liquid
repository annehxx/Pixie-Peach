{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-collection-showcase.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign selected_collection = section.settings.collection
  assign product_limit = section.settings.products_to_show
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --collection-showcase-columns-desktop: {{ columns_desktop_int }};
    --collection-showcase-columns-mobile: {{ columns_mobile_int }};
    --collection-showcase-gap-desktop: {{ section.settings.grid_gap_desktop }}px;
    --collection-showcase-gap-mobile: {{ section.settings.grid_gap_mobile }}px;
    --collection-showcase-card-radius: {{ section.settings.image_radius }}px;
    --collection-showcase-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --collection-showcase-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --collection-showcase-link-color: {{ section.settings.link_color }};
    --collection-showcase-price-color: {{ section.settings.price_color }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="collection-showcase section-{{ section.id }}-padding" id="collection-{{ section.id }}" data-id="{{ section.id }}">
  <div class="page-width">
    <div class="collection-showcase__header">
      <div class="collection-showcase__title-wrapper">
        {%- if section.settings.title != blank -%}
          <h2 class="collection-showcase__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>

      {%- if section.settings.show_view_all and selected_collection != blank -%}
        <a href="{{ selected_collection.url }}" class="collection-showcase__link">
          {{ section.settings.link_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if selected_collection != blank and selected_collection.products.size > 0 -%}
      <div class="collection-showcase__grid">
        {%- for product in selected_collection.products limit: product_limit -%}
          {%- liquid
            assign product_image_alt = product.featured_media.alt | default: product.title
          -%}
          <article class="collection-showcase__card">
            <a href="{{ product.url }}" class="collection-showcase__image-link">
              <div class="collection-showcase__image-wrap">
                {%- if product.featured_media != blank -%}
                  {{
                    product.featured_media
                    | image_url: width: 1100
                    | image_tag:
                      class: 'collection-showcase__image',
                      widths: '360, 533, 720, 940, 1100',
                      sizes: '(min-width: 1200px) 24vw, (min-width: 750px) 48vw, 100vw',
                      alt: product_image_alt,
                      loading: 'lazy'
                  }}
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'collection-showcase__image collection-showcase__image--placeholder' }}
                {%- endif -%}
              </div>
            </a>

            <div class="collection-showcase__content">
              <h3 class="collection-showcase__product-title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <div class="collection-showcase__price">
                {% render 'price', product: product, price_class: 'collection-showcase__price-render', show_compare_at_price: false %}
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="collection-showcase__empty">
        Select a collection with products to populate this section.
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Showcase",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Disco All The Time!",
      "label": "Title"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "link_label",
      "default": "Shop Disco Collection",
      "label": "Collection link label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ],
      "default": "1",
      "label": "Columns on mobile"
    },
    {
      "type": "range",
      "id": "grid_gap_desktop",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap desktop",
      "default": 12
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Gap mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Image radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 32,
      "max": 84,
      "step": 2,
      "unit": "px",
      "label": "Heading size desktop",
      "default": 62
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 26,
      "max": 58,
      "step": 2,
      "unit": "px",
      "label": "Heading size mobile",
      "default": 38
    },
    {
      "type": "color",
      "id": "link_color",
      "default": "#8f85e7",
      "label": "Link color"
    },
    {
      "type": "color",
      "id": "price_color",
      "default": "#28222a",
      "label": "Price color"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show collection link"
    },
    {
      "type": "header",
      "content": "Legacy"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show secondary image"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show rating"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "default": false,
      "label": "Enable desktop slider"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "Enable swipe on mobile"
    },
    {
      "type": "select",
      "id": "quick_add",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "bulk",
          "label": "Bulk"
        }
      ],
      "default": "none",
      "label": "Quick add"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Collection Showcase",
      "settings": {
        "title": "Disco All The Time!"
      }
    }
  ]
}
{% endschema %}
