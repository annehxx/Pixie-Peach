{{ 'section-pps-about-us.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign about_image_alt = section.settings.image.alt | default: section.settings.heading | escape
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --pps-about-bg: {{ section.settings.background_color }};
    --pps-about-heading: {{ section.settings.heading_color }};
    --pps-about-text: {{ section.settings.text_color }};
    --pps-about-accent: {{ section.settings.accent_color }};
    --pps-about-card-bg: {{ section.settings.card_background }};
    --pps-about-button-bg: {{ section.settings.button_background }};
    --pps-about-button-text: {{ section.settings.button_text_color }};
    --pps-about-padding-top: {{ section.settings.padding_top }}px;
    --pps-about-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pps-about-gap: {{ section.settings.column_gap }}px;
    --pps-about-radius: {{ section.settings.panel_radius }}px;
  }
{% endstyle %}

<section class="pps-about">
  <div class="pps-about__inner page-width">
    <div class="pps-about__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pps-about__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="pps-about__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text_1 != blank -%}
        <div class="pps-about__text rte">{{ section.settings.text_1 }}</div>
      {%- endif -%}

      {%- if section.settings.text_2 != blank -%}
        <div class="pps-about__text rte">{{ section.settings.text_2 }}</div>
      {%- endif -%}

      {%- if section.settings.highlight != blank -%}
        <div class="pps-about__highlight">{{ section.settings.highlight }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          class="pps-about__button"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="pps-about__media">
      <div class="pps-about__card">
        <div class="pps-about__media-frame">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag:
                class: 'pps-about__image',
                widths: '500, 700, 900, 1100, 1400',
                alt: about_image_alt,
                loading: 'lazy'
            }}
          {%- else -%}
            <div class="pps-about__placeholder">
              {{ 'image' | placeholder_svg_tag: 'pps-about__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.card_caption != blank -%}
          <div class="pps-about__caption">{{ section.settings.card_caption }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPS About Us",
  "tag": "section",
  "class": "section-pps-about",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About Pixie Peach"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cute, playful pieces with main character energy."
    },
    {
      "type": "richtext",
      "id": "text_1",
      "label": "First paragraph",
      "default": "<p>Pixie Peach is all about dreamy, feminine style with a little sparkle and a little chaos. We create pieces that feel flirty, nostalgic, and unapologetically fun.</p>"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Second paragraph",
      "default": "<p>From sweet statement graphics to soft coquette-inspired details, everything is designed to feel wearable, expressive, and very online in the best way.</p>"
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight line",
      "default": "Made for pink lovers, soft hearts, and girls who romanticize everything."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the vibe"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_caption",
      "label": "Image caption",
      "default": "Soft girl energy, bottled into a brand."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Column gap",
      "default": 72
    },
    {
      "type": "range",
      "id": "panel_radius",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Panel radius",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#fff8fc"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2f2137"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6d5a71"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#e57abb"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Image card background",
      "default": "#f7d4e8"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#8f85e7"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "PPS About Us"
    }
  ]
}
{% endschema %}
