{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-pps-featured-favorites.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign featured_collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --pps-favorites-bg: {{ section.settings.background_color }};
    --pps-favorites-heading: {{ section.settings.heading_color }};
    --pps-favorites-text: {{ section.settings.text_color }};
    --pps-favorites-link: {{ section.settings.link_color }};
    --pps-favorites-price: {{ section.settings.price_color }};
    --pps-favorites-gap: {{ section.settings.grid_gap }}px;
    --pps-favorites-padding-top: {{ section.settings.padding_top }}px;
    --pps-favorites-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pps-favorites-card-radius: {{ section.settings.card_radius }}px;
    --pps-favorites-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --pps-favorites-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --pps-favorites-image-ratio: {{ section.settings.image_ratio }};
  }
{% endstyle %}

<section class="pps-favorites">
  <div class="pps-favorites__inner page-width">
    <div class="pps-favorites__header">
      <div class="pps-favorites__header-copy">
        {%- if section.settings.heading != blank -%}
          <h2 class="pps-favorites__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <div class="pps-favorites__subtext rte">{{ section.settings.subtext }}</div>
        {%- endif -%}
      </div>

      {%- if section.settings.link_label != blank and featured_collection != blank -%}
        <a href="{{ featured_collection.url }}" class="pps-favorites__section-link">
          {{ section.settings.link_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="pps-favorites__grid">
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: products_to_show -%}
          {%- liquid
            assign product_image_alt = product.featured_image.alt | default: product.title | escape
          -%}
          <article class="pps-favorites__card">
            <a href="{{ product.url }}" class="pps-favorites__image-link">
              <div class="pps-favorites__image-wrap">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'pps-favorites__image',
                      widths: '280, 360, 480, 640, 760, 900',
                      sizes: '(min-width: 1200px) 24vw, (min-width: 750px) 32vw, 88vw',
                      alt: product_image_alt,
                      loading: 'lazy'
                  }}
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'pps-favorites__image pps-favorites__image--placeholder' }}
                {%- endif -%}
              </div>
            </a>

            <div class="pps-favorites__content">
              <h3 class="pps-favorites__product-title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="pps-favorites__price">
                {% render 'price', product: product, price_class: 'pps-favorites__price-render', show_compare_at_price: false %}
              </div>

              <a href="{{ product.url }}" class="pps-favorites__button">
                {%- if product.has_only_default_variant -%}
                  {{ section.settings.button_label_default }}
                {%- else -%}
                  {{ section.settings.button_label_options }}
                {%- endif -%}
              </a>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <article class="pps-favorites__card">
            <div class="pps-favorites__image-wrap">
              {{ 'product-apparel-1' | placeholder_svg_tag: 'pps-favorites__image pps-favorites__image--placeholder' }}
            </div>
            <div class="pps-favorites__content">
              <h3 class="pps-favorites__product-title">Sample product {{ i }}</h3>
              <div class="pps-favorites__price">EUR 39.95</div>
              <span class="pps-favorites__button">{{ section.settings.button_label_options }}</span>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPS Featured Favorites",
  "tag": "section",
  "class": "section-pps-featured-favorites",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pixie Picks Right Now"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Sweet, playful favourites curated for your main character era.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Section link label",
      "default": "Shop Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label_default",
      "label": "Button label for single-variant products",
      "default": "View product"
    },
    {
      "type": "text",
      "id": "button_label_options",
      "label": "Button label for multi-variant products",
      "default": "Choose options"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Grid gap",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Card radius",
      "default": 16
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "default": "0.8",
      "options": [
        {
          "value": "0.72",
          "label": "Tall"
        },
        {
          "value": "0.8",
          "label": "Portrait"
        },
        {
          "value": "1",
          "label": "Square"
        }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 32,
      "max": 82,
      "step": 2,
      "unit": "px",
      "label": "Heading size desktop",
      "default": 58
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 26,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#fffafc"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2f2137"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#715b70"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#8f85e7"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#2f2137"
    }
  ],
  "presets": [
    {
      "name": "PPS Featured Favorites"
    }
  ]
}
{% endschema %}
