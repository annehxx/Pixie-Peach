{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}
{{ 'section-pps-contact-us.css' | asset_url | stylesheet_tag }}

{% style %}
  #shopify-section-{{ section.id }} {
    --pps-contact-bg: {{ section.settings.background_color }};
    --pps-contact-heading: {{ section.settings.heading_color }};
    --pps-contact-text: {{ section.settings.text_color }};
    --pps-contact-accent: {{ section.settings.accent_color }};
    --pps-contact-card-bg: {{ section.settings.form_background }};
    --pps-contact-button-bg: {{ section.settings.button_background }};
    --pps-contact-button-text: {{ section.settings.button_text_color }};
    --pps-contact-padding-top: {{ section.settings.padding_top }}px;
    --pps-contact-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pps-contact-gap: {{ section.settings.column_gap }}px;
    --pps-contact-radius: {{ section.settings.panel_radius }}px;
  }
{% endstyle %}

<section class="pps-contact">
  <div class="pps-contact__inner page-width">
    <div class="pps-contact__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pps-contact__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="pps-contact__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="pps-contact__text rte">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="pps-contact__details">
        {%- if section.settings.email != blank -%}
          <a href="mailto:{{ section.settings.email }}" class="pps-contact__detail">
            {{ section.settings.email }}
          </a>
        {%- endif -%}

        {%- if section.settings.instagram_label != blank and section.settings.instagram_link != blank -%}
          <a href="{{ section.settings.instagram_link }}" class="pps-contact__detail">
            {{ section.settings.instagram_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.response_note != blank -%}
          <p class="pps-contact__note">{{ section.settings.response_note }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="pps-contact__form-card">
      {%- form 'contact', id: 'PpsContactForm', class: 'pps-contact__form isolate' -%}
        {%- if form.posted_successfully? -%}
          <h3 class="form-status form-status-list form__message pps-contact__message" tabindex="-1" autofocus>
            {{- 'icon-success.svg' | inline_asset_content -}}
            {{ section.settings.success_message }}
          </h3>
        {%- elsif form.errors -%}
          <div class="pps-contact__message">
            <h3 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
              {{- 'icon-error.svg' | inline_asset_content -}}
              {{ 'templates.contact.form.error_heading' | t }}
            </h3>
          </div>
        {%- endif -%}

        <div class="contact__fields">
          <div class="field">
            <input
              class="field__input"
              autocomplete="name"
              type="text"
              id="PpsContactForm-name"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ 'templates.contact.form.name' | t }}"
            >
            <label class="field__label" for="PpsContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
          </div>

          <div class="field field--with-error">
            <input
              autocomplete="email"
              type="email"
              id="PpsContactForm-email"
              class="field__input"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="PpsContactForm-email-error"
              {% endif %}
              placeholder="{{ 'templates.contact.form.email' | t }}"
            >
            <label class="field__label" for="PpsContactForm-email">
              {{- 'templates.contact.form.email' | t }}
              <span aria-hidden="true">*</span>
            </label>
            {%- if form.errors contains 'email' -%}
              <small class="contact__field-error" id="PpsContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message">
                  <span class="svg-wrapper">
                    {{- 'icon-error.svg' | inline_asset_content -}}
                  </span>
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
        </div>

        <div class="field">
          <input
            type="tel"
            id="PpsContactForm-phone"
            class="field__input"
            autocomplete="tel"
            name="contact[{{ 'templates.contact.form.phone' | t }}]"
            pattern="[0-9\\-]*"
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            placeholder="{{ 'templates.contact.form.phone' | t }}"
          >
          <label class="field__label" for="PpsContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
        </div>

        <div class="field">
          <textarea
            rows="8"
            id="PpsContactForm-body"
            class="text-area field__input"
            name="contact[{{ 'templates.contact.form.comment' | t }}]"
            placeholder="{{ 'templates.contact.form.comment' | t }}"
          >{{- form.body -}}</textarea>
          <label class="form__label field__label" for="PpsContactForm-body">
            {{- 'templates.contact.form.comment' | t -}}
          </label>
        </div>

        <div class="contact__button pps-contact__button-wrap">
          <button type="submit" class="pps-contact__button">
            {{ section.settings.button_label }}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPS Contact Us",
  "tag": "section",
  "class": "section-pps-contact",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let's talk, babe."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Questions about your order, sizing, custom ideas, or just want to say hi? Send us a message and we'll get back to you as soon as we can.</p>"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@pixiepeach.com"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "Secondary contact label",
      "default": "@pixiepeachstudios"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Secondary contact link"
    },
    {
      "type": "text",
      "id": "response_note",
      "label": "Response note",
      "default": "Usually answered within 1-3 business days."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit button label",
      "default": "Send message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Your message is on its way. We'll be in touch soon."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Column gap",
      "default": 64
    },
    {
      "type": "range",
      "id": "panel_radius",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Panel radius",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#fff8fc"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2f2137"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#6d5a71"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#e57abb"
    },
    {
      "type": "color",
      "id": "form_background",
      "label": "Form card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#8f85e7"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "PPS Contact Us"
    }
  ]
}
{% endschema %}
